@startuml ui-input-action-class-relationship
!theme plain
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontSize 13
skinparam classFontSize 13

title 筷子输入法 - 输入动作程序化类关系\nInput Action Playback Class Relationships

' ─── Script Model ──────────────────────────────────────────────────

package "脚本模型\nScript Model\n[:ime-engine]" as script_pkg #FFF3E0 {

    class InputActionScript {
        + name: String
        + description: String
        + actions: List<InputAction>
    }

    abstract class InputAction {
        + startTime: Long
    }

    class KeyDown {
        + key: InputKey
    }

    class KeyUp {
        + key: InputKey
    }

    class SwipeTo {
        + fromKey: InputKey
        + toKey: InputKey
        + duration: Long
    }

    class Wait {
        + duration: Long
    }

    class SelectCandidate {
        + candidateIndex: Int
    }

    class SwitchKeyboard {
        + targetType: KeyboardType
    }
}

' ─── Playback State ────────────────────────────────────────────────

package "播放状态\nPlayback State\n[:ime-ui]" as state_pkg #F3E5F5 {

    abstract class InputActionPlaybackState
    class Idle
    class Ready {
        + script: InputActionScript
    }
    class Playing {
        + currentIndex: Int
        + totalActions: Int
    }
    class Paused {
        + currentIndex: Int
        + totalActions: Int
    }
    class Finished
}

' ─── Player ────────────────────────────────────────────────────────

package "播放器\nPlayer\n[:ime-ui]" as player_pkg #E8F5E9 {

    class InputActionPlayer {
        - viewModel: KeyboardViewModel
        - feedbackState: GestureFeedbackState
        - positionResolver: InputActionPositionResolver
        - scope: CoroutineScope
        - job: Job?
        - currentScript: InputActionScript?
        - actionIndex: Int
        - _trailPoints: MutableStateFlow<List<OffsetF>>
        + playbackState: StateFlow<InputActionPlaybackState>
        + speed: StateFlow<Float>
        + trailPoints: StateFlow<List<OffsetF>>
        + load(script: InputActionScript)
        + play()
        + pause()
        + resume()
        + stop()
        + stepForward()
        + setSpeed(speed: Float)
        - executeAction(action: InputAction)
        - animateFingerAlongPath(feedbackState, path, duration)
        - showIndicator(position: OffsetF, pressed: Boolean)
    }
}

' ─── Coordinate Resolution ────────────────────────────────────────

package "坐标解析\nCoordinate Resolution\n[:ime-ui]" as coord_pkg #E3F2FD {

    interface InputActionPositionResolver {
        + resolve(key: InputKey): OffsetF?
        + resolveCandidatePosition(index: Int): OffsetF?
    }

    class ComposeInputActionPositionResolver {
        - keyLayoutProvider: () -> KeyLayoutState?
        - candidateLayoutProvider: () -> CandidateListLayoutState?
        - inputListLayoutProvider: () -> InputListLayoutState?
        - coordinateNormalizer: CoordinateNormalizer
        + resolve(key: InputKey): OffsetF?
        + resolveCandidatePosition(index: Int): OffsetF?
    }

    class KeyLayoutState {
        + keyPositions: Map<InputKey, Rect>
    }

    class CandidateListLayoutState {
        + candidatePositions: List<Rect>
    }

    class InputListLayoutState {
        + itemPositions: List<Rect>
    }
}

' ─── Coordinate Normalizer ────────────────────────────────────────

package "坐标归一化\nCoordinate Normalizer\n[:ime-ui]" as norm_pkg #FCE4EC {

    class CoordinateNormalizer {
        + normalize(offset: Offset, bounds: Rect): OffsetF
        + denormalize(offsetF: OffsetF, bounds: Rect): Offset
        + 归一化坐标用于跨区域传递
        + 绝对坐标用于实际绘制
    }
}

' ─── Path Interpolation ───────────────────────────────────────────

package "路径插值\nPath Interpolation\n[:ime-ui]" as path_pkg #FFF9C4 {

    class InputActionPathInterpolator <<object>> {
        + interpolate(from: OffsetF, to: OffsetF,\narcFactor: Float, steps: Int): List<OffsetF>
    }
}

' ─── Feedback State ────────────────────────────────────────────────

package "反馈状态\nFeedback State\n[:ime-ui]" as feedback_pkg #FFE0B2 {

    class GestureFeedbackState {
        - _touchTrailPoints: MutableStateFlow<List<OffsetF>>
        - _pressedKeys: MutableStateFlow<Set<InputKey>>
        - _fingerIndicator: MutableStateFlow<InputActionFingerIndicator?>
        + touchTrailPoints: StateFlow<List<OffsetF>>
        + pressedKeys: StateFlow<Set<InputKey>>
        + fingerIndicator: StateFlow<InputActionFingerIndicator?>
        + setFingerIndicator(state: InputActionFingerIndicator?)
        + addTouchTrailPoint(normalizedOffset: OffsetF)
        + setPressedKeys(keys: Set<InputKey>)
        + clearPressedKeys()
        + clearAll()
    }

    class InputActionFingerIndicator {
        + position: OffsetF
        + pressed: Boolean
        + visible: Boolean
    }


}

' ─── Script Loader ────────────────────────────────────────────────

package "脚本加载\nScript Loader\n[:app]" as loader_pkg #D1C4E9 {

    class InputActionScriptLoader {
        - context: Context
        + loadPreset(name: String): InputActionScript
        + listPresets(): List<String>
        + loadFromFile(uri: Uri): InputActionScript
        - parseScript(json: String): InputActionScript
    }
}

' ─── ViewModel ─────────────────────────────────────────────────────

package "ViewModel\n[:ime-ui]" as vm_pkg #C8E6C9 {

    class KeyboardViewModel {
        - engine: ImeEngine
        - feedbackState: GestureFeedbackState
        + state: StateFlow<ImeState>
        + handleGesture(gesture: InputGesture)
        + handleIntent(intent: ImeIntent)
        + updateConfig(config: ImeConfig)
    }
}

' ─── UI Components ─────────────────────────────────────────────────

package "UI 组件\nUI Components\n[:ime-ui]" as ui_pkg #E3F2FD {

    class KeyboardInputActionPlayerHost <<@Composable>> {
        + KeyboardHost
        + ActionPlayerPanel
        + 内置指示器 (showIndicator)
        + 无外部覆盖层
    }

    class ActionPlayerPanel <<@Composable>> {
        + 播放 / 暂停 / 停止按钮
        + 步进按钮
        + 速度滑块
    }

    class GestureFeedbackPanel <<@Composable>> {
        + elements: Set<FeedbackElementType>
        + 内置 TouchTrail / KeyHighlight / FingerIndicator
        + 读取 GestureFeedbackState
        + CoordinateNormalizer.denormalize() 绘制
    }
}

' ─── KeyboardHost ─────────────────────────────────────────────────

package "KeyboardHost\n键盘宿主\n[:ime-ui]" as kh_pkg #BBDEFB {
    class KeyboardHost <<@Composable>> {
        + Zone A Container (Separated 模式)
        + Zone B Container (三行布局)
        + GestureInputPanel (Zone B Row3 顶层)
        + GestureFeedbackPanel (多实例)
        + KeyLayoutPanel (底层)
        + CandidateListPanel + PopupTipPanel (Row1)
        + ToolListPanel / InputListPanel (Row2)
    }
}

' ─── Inheritance ───────────────────────────────────────────────────

InputAction <|-- KeyDown
InputAction <|-- KeyUp
InputAction <|-- SwipeTo
InputAction <|-- Wait
InputAction <|-- SelectCandidate
InputAction <|-- SwitchKeyboard

InputActionPlaybackState <|-- Idle
InputActionPlaybackState <|-- Ready
InputActionPlaybackState <|-- Playing
InputActionPlaybackState <|-- Paused
InputActionPlaybackState <|-- Finished

InputActionPositionResolver <|.. ComposeInputActionPositionResolver

' ─── Composition ───────────────────────────────────────────────────

InputActionPlayer *-- InputActionPlaybackState : "播放状态"
InputActionPlayer o-- InputActionScript : "当前脚本"
InputActionPlayer --> KeyboardViewModel : "发送 ImeIntent"
InputActionPlayer --> GestureFeedbackState : "更新手指指示器\nshowIndicator"
InputActionPlayer --> InputActionPositionResolver : "查询归一化位置 OffsetF"
InputActionPlayer --> InputActionPathInterpolator : "计算路径 (OffsetF)"
InputActionPlayer --> InputActionFingerIndicator : "创建"


ComposeInputActionPositionResolver --> KeyLayoutState : "读取"
ComposeInputActionPositionResolver --> CandidateListLayoutState : "读取"
ComposeInputActionPositionResolver --> InputListLayoutState : "读取"
ComposeInputActionPositionResolver --> CoordinateNormalizer : "归一化坐标转换"

GestureFeedbackState *-- InputActionFingerIndicator : "fingerIndicator"

InputActionScriptLoader ..> InputActionScript : "加载并解析"

KeyboardViewModel *-- GestureFeedbackState : "持有"
KeyboardViewModel --> ImeEngine : "持有引用"

KeyboardInputActionPlayerHost *-- KeyboardHost
KeyboardInputActionPlayerHost *-- ActionPlayerPanel

ActionPlayerPanel --> InputActionPlayer : "控制播放"

KeyboardHost ..> KeyLayoutState : "提供布局状态"
KeyboardHost ..> CandidateListLayoutState : "提供布局状态"

GestureFeedbackPanel --> CoordinateNormalizer : "denormalize 绘制"

' ─── Legend ─────────────────────────────────────────────────────────

legend right
    |= 颜色 |= 所属模块 / 层 |
    |<#FFF3E0>| :ime-engine 脚本模型 |
    |<#E8F5E9>| :ime-ui 播放器 |
    |<#E3F2FD>| :ime-ui 坐标解析与 UI 组件 |
    |<#FCE4EC>| :ime-ui 坐标归一化 |
    |<#FFE0B2>| :ime-ui 反馈状态 |
    |<#D1C4E9>| :app 脚本加载 |
    |<#FFF9C4>| :ime-ui 路径插值 |
    |<#BBDEFB>| KeyboardHost |
endlegend

@enduml
