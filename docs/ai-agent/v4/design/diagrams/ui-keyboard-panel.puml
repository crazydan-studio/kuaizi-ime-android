@startuml ui-keyboard-panel
!theme plain
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontSize 13
skinparam classFontSize 13

title 筷子输入法 - KeyboardPanel / KeyboardScreen 组合\nKeyboardPanel & KeyboardScreen Composition

' ─── KeyboardPanel (Overlay Mode) ──────────────────────────────────

package "KeyboardPanel\n键盘面板 (浮层模式 / Overlay Mode)" as KPOverlay #E3F2FD {

    rectangle "Column" as col1 {
        rectangle "CandidateListPanel\n候选词面板" as clp1 #E8F5E9 {
            rectangle "LazyRow { candidates }" as clp1_items
        }

        rectangle "InputListPanel\n输入缓冲面板" as ilp1 #E8F5E9 {
            rectangle "显示拼音缓冲 / composing text" as ilp1_content
        }

        rectangle "Box (层叠容器)" as box1 #FFF3E0 {
            rectangle "KeyGridPanel\n按键网格 (底层)\n纯展示，ImeState 驱动" as kgp1 #BBDEFB {
                rectangle "KeyboardLayout\n按键布局" as kl1
            }
            rectangle "GestureFeedbackPanel\n手势反馈 (中层)\nOverlaySet.allElements" as gfp1 #C8E6C9 {
                rectangle "TouchTrail + KeyHighlight + KeyPath\n+ XPadPathHighlight + FingerIndicator" as gf1
            }
            rectangle "GestureInputPanel\n手势输入 (顶层)\n透明手势拦截层" as gip1 #FFCCBC {
                rectangle "pointerInput { detectGesture }\n触摸手势检测 → InputGesture" as gi1
            }
        }

        rectangle "Toolbar\n工具栏" as tb1 #F3E5F5 {
            rectangle "切换布局 / 设置 / 收藏" as tb1_items
        }
    }

    clp1 -down-> ilp1
    ilp1 -down-> box1
    box1 -down-> tb1
    kgp1 -[hidden]up- gfp1
    gfp1 -[hidden]up- gip1
}

' ─── KeyboardScreen (Fullscreen Mode) ──────────────────────────────

package "KeyboardScreen\n键盘屏幕 (全屏模式 / Fullscreen Mode)" as KSFull #E8F5E9 {

    rectangle "Box (全屏容器)" as box2_outer {
        rectangle "Column" as col2 {
            rectangle "CandidateListPanel\n候选词面板" as clp2 #E3F2FD {
                rectangle "LazyRow { candidates }" as clp2_items
            }

            rectangle "InputListPanel\n输入缓冲面板" as ilp2 #E3F2FD {
                rectangle "显示拼音缓冲 + 已提交文本" as ilp2_content
            }

            rectangle "Box: GestureInputPanel + Feedback(输入侧)" as gip2_box #FFCCBC {
                rectangle "GestureInputPanel\n手势输入 (顶层)" as gip2_outer
                rectangle "GestureFeedbackPanel\n输入侧反馈 (底层)\nTouchTrail + FingerIndicator" as gfp2_input #C8E6C9
            }

            rectangle "Box: Feedback(按键侧) + KeyGridPanel" as kgp2_box #BBDEFB {
                rectangle "GestureFeedbackPanel\n按键侧反馈 (底层)\nKeyHighlight + KeyPath + XPadPathHighlight" as gfp2_key #C8E6C9
                rectangle "KeyGridPanel\n按键网格" as kgp2_outer
            }

            rectangle "Toolbar\n工具栏" as tb2 #F3E5F5 {
                rectangle "切换布局 / 设置 / 收藏" as tb2_items
            }
        }
    }

    clp2 -down-> ilp2
    ilp2 -down-> gip2_box
    gip2_box -down-> kgp2_box
    kgp2_box -down-> tb2
}

' ─── Shared Components ─────────────────────────────────────────────

package "共享组件\nShared Components" as shared #F3E5F5 {
    component [KeyboardViewModel\n键盘视图模型\n(viewModel 为必填参数)] as KVM
    component [ImeEngine\n输入法引擎] as IE
    component [GestureFeedbackState\n手势反馈状态] as GFS
    component [KeyPositionResolver\n按键位置解析] as KPR

    KVM --> IE : "持有引用\n(不持有 InputConnectionBridge)"
    KVM --> GFS : "持有"
}

' ─── Data Flow ─────────────────────────────────────────────────────

gip1 ..> KVM : "InputGesture → handleGesture()"
gip2_outer ..> KVM : "InputGesture → handleGesture()"
KVM --> IE : "ImeIntent → handleIntent()"
IE ..> clp1 : "StateFlow<ImeState>"
IE ..> clp2 : "StateFlow<ImeState>"
IE ..> kgp1 : "StateFlow<ImeState>"
IE ..> kgp2_outer : "StateFlow<ImeState>"
GFS ..> gfp1 : "反馈渲染"
GFS ..> gfp2_input : "反馈渲染"
GFS ..> gfp2_key : "反馈渲染"

' ─── Comparison Notes ──────────────────────────────────────────────

note bottom of KPOverlay
    **浮层模式 (Overlay Mode)**
    - 手势输入与按键面板叠加在 Box 中
    - GestureFeedbackPanel 单实例 (OverlaySet)
    - 适用于普通输入场景
    - 占据屏幕底部区域

    viewModel 为必填参数（无默认值）
    InputConnectionBridge 不由 ViewModel 持有
end note

note bottom of KSFull
    **全屏模式 (Fullscreen Mode)**
    - 手势输入区域独立
    - GestureFeedbackPanel 双实例 (FullScreenSet)
      - 输入侧：TouchTrail + FingerIndicator
      - 按键侧：KeyHighlight + KeyPath + XPadPathHighlight
    - 适用于横屏/平板场景
    - 占据更大屏幕区域
end note

@enduml
