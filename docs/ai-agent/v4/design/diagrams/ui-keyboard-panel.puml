@startuml ui-keyboard-panel
!theme plain
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontSize 13
skinparam classFontSize 13

title 筷子输入法 - KeyboardPanel / KeyboardScreen 组合\nKeyboardPanel & KeyboardScreen Composition

' ─── KeyboardPanel (Overlay Mode) ──────────────────────────────────

package "KeyboardPanel\n键盘面板 (浮层模式 / Overlay Mode)" as KPOverlay #E3F2FD {

    rectangle "Column" as col1 {
        rectangle "CandidateListPanel\n候选词面板" as clp1 #E8F5E9 {
            rectangle "LazyRow { candidates }" as clp1_items
        }

        rectangle "InputListPanel\n输入缓冲面板" as ilp1 #E8F5E9 {
            rectangle "显示拼音缓冲 / composing text" as ilp1_content
        }

        rectangle "Box (层叠容器)" as box1 #FFF3E0 {
            rectangle "KeyGridPanel\n按键网格 (底层)" as kgp1 #BBDEFB {
                rectangle "KeyboardLayout\n按键布局" as kl1
            }
            rectangle "GestureFeedbackPanel\n手势反馈 (中层)" as gfp1 #C8E6C9 {
                rectangle "GestureLine + HintText\n滑行路径 + 提示文字" as gf1
            }
            rectangle "GestureInputPanel\n手势输入 (顶层)" as gip1 #FFCCBC {
                rectangle "pointerInput { detectGesture }\n触摸手势检测" as gi1
            }
        }

        rectangle "Toolbar\n工具栏" as tb1 #F3E5F5 {
            rectangle "切换布局 / 设置 / 收藏" as tb1_items
        }
    }

    clp1 -down-> ilp1
    ilp1 -down-> box1
    box1 -down-> tb1
    kgp1 -[hidden]up- gfp1
    gfp1 -[hidden]up- gip1
}

' ─── KeyboardScreen (Fullscreen Mode) ──────────────────────────────

package "KeyboardScreen\n键盘屏幕 (全屏模式 / Fullscreen Mode)" as KSFull #E8F5E9 {

    rectangle "Box (全屏容器)" as box2_outer {
        rectangle "Column" as col2 {
            rectangle "CandidateListPanel\n候选词面板" as clp2 #E3F2FD {
                rectangle "LazyRow { candidates }" as clp2_items
            }

            rectangle "InputListPanel\n输入缓冲面板" as ilp2 #E3F2FD {
                rectangle "显示拼音缓冲 + 已提交文本" as ilp2_content
            }

            rectangle "GestureInputPanel\n手势输入 (独立区域)" as gip2_outer #FFCCBC {
                rectangle "pointerInput { detectGesture }\n全屏手势检测区域" as gi2
            }

            rectangle "KeyGridPanel\n按键网格 (独立区域)" as kgp2_outer #BBDEFB {
                rectangle "KeyboardLayout + GestureFeedbackPanel\n按键 + 反馈叠加" as kl2
            }

            rectangle "Toolbar\n工具栏" as tb2 #F3E5F5 {
                rectangle "切换布局 / 设置 / 收藏" as tb2_items
            }
        }
    }

    clp2 -down-> ilp2
    ilp2 -down-> gip2_outer
    gip2_outer -down-> kgp2_outer
    kgp2_outer -down-> tb2
}

' ─── Shared Components ─────────────────────────────────────────────

package "共享组件\nShared Components" as shared #F3E5F5 {
    component [KeyboardViewModel\n键盘视图模型] as KVM
    component [ImeEngine\n输入法引擎] as IE
    component [InputConnectionBridge\n输入连接桥] as ICB
    component [GestureRecognizer\n手势识别器] as GR

    KVM --> IE : "持有"
    KVM --> ICB : "持有"
}

' ─── Data Flow ─────────────────────────────────────────────────────

gip1 ..> KVM : "ImeIntent"
gip2_outer ..> KVM : "ImeIntent"
KVM --> IE : "reduce()"
IE ..> clp1 : "StateFlow"
IE ..> clp2 : "StateFlow"
IE ..> kgp1 : "StateFlow"
IE ..> kgp2_outer : "StateFlow"
KVM --> ICB : "commitText()"

gip1 --> GR : "使用"
gip2_outer --> GR : "使用"

' ─── Comparison Notes ──────────────────────────────────────────────

note bottom of KPOverlay
    **浮层模式 (Overlay Mode)**
    - 手势输入与按键面板叠加在 Box 中
    - 手势覆盖在按键上方
    - 适用于普通输入场景
    - 占据屏幕底部区域
    
    Gesture input overlays key panel in Box.
    Used for normal input scenarios.
end note

note bottom of KSFull
    **全屏模式 (Fullscreen Mode)**
    - 手势输入区域独立
    - 按键网格与反馈叠加
    - 适用于横屏/平板场景
    - 占据更大屏幕区域
    
    Gesture input is in a separate area.
    Used for landscape/tablet scenarios.
end note

@enduml
