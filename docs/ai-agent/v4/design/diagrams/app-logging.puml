@startuml app-logging
!theme plain
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontSize 13
skinparam classFontSize 13

title 筷子输入法 - 日志系统\nLogging System

' ─── Facade ────────────────────────────────────────────────────────

class ImeLog <<门面 Facade>> #E3F2FD {
    + {static} v(tag: String, msg: String)
    + {static} d(tag: String, msg: String)
    + {static} i(tag: String, msg: String)
    + {static} w(tag: String, msg: String)
    + {static} e(tag: String, msg: String, throwable?: Throwable)
    + {static} init(context: Context)
    + {static} setLevel(level: LogLevel)
    + {static} flush()
}

' ─── Logger Core ───────────────────────────────────────────────────

class ImeLogger <<核心 Core>> #E8F5E9 {
    - writers: List<LogWriter>
    - level: LogLevel
    - crashInterceptor: CrashInterceptor?
    + log(level: LogLevel, tag: String, msg: String)
    + addWriter(writer: LogWriter)
    + removeWriter(writer: LogWriter)
    + setLevel(level: LogLevel)
    + flush()
}

' ─── Writers ───────────────────────────────────────────────────────

interface LogWriter <<接口>> {
    + write(entry: LogEntry)
    + flush()
    + close()
}

class LogcatWriter <<Writer>> #FFF3E0 {
    - tagPrefix: String
    + write(entry: LogEntry)
    + flush()
    + close()
    note: "Android Logcat 输出"
}

class FileLogWriter <<Writer>> #FFF3E0 {
    - logStorage: LogStorage
    - formatter: LogFormatter
    + write(entry: LogEntry)
    + flush()
    + close()
    note: "文件日志输出"
}

class CrashInterceptor <<拦截器>> #FCE4EC {
    - lastEntries: CircularBuffer<LogEntry>
    - crashFilePath: String
    + intercept(entry: LogEntry)
    + dumpOnCrash(throwable: Throwable)
    + getCrashLog(): String?
    note: "崩溃日志拦截"
}

' ─── Storage ───────────────────────────────────────────────────────

class LogStorage <<存储管理>> #F3E5F5 {
    - logDir: File
    - maxFileSize: Long
    - maxFileCount: Int
    - currentFile: File
    + write(line: String)
    + rotateIfNeeded()
    + getLogFiles(): List<File>
    + clearOldLogs()
    + getCurrentLog(): String
}

' ─── Log Level ─────────────────────────────────────────────────────

enum LogLevel #E0F7FA {
    VERBOSE = 0
    DEBUG = 1
    INFO = 2
    WARN = 3
    ERROR = 4
}

class LogEntry <<数据类>> {
    + timestamp: Long
    + level: LogLevel
    + tag: String
    + message: String
    + throwable: Throwable?
}

class LogFormatter <<格式化>> {
    + {static} format(entry: LogEntry): String
    + {static} formatTimestamp(ts: Long): String
    + {static} formatThrowable(t: Throwable): String
}

class CircularBuffer<T> <<环形缓冲>> {
    - buffer: Array<T?>
    - head: Int
    - size: Int
    + add(item: T)
    + getAll(): List<T>
    + clear()
}

' ─── Relationships ─────────────────────────────────────────────────

ImeLog --> ImeLogger : "委托\ndelegates to"
ImeLogger --> LogWriter : "分发\ndispatches to"
ImeLogger --> CrashInterceptor : "拦截\nintercepts"

LogWriter <|.. LogcatWriter : "实现\nimplements"
LogWriter <|.. FileLogWriter : "实现\nimplements"

FileLogWriter --> LogStorage : "写入\nwrites to"
FileLogWriter --> LogFormatter : "格式化\nformats with"
CrashInterceptor --> CircularBuffer : "缓冲\nbuffers in"

ImeLogger --> LogLevel : "过滤\nfilters by"
LogEntry --> LogLevel : "包含\ncontains"

' ─── Log Level Hierarchy ──────────────────────────────────────────

package "日志级别层级\nLog Level Hierarchy" as levelHierarchy #E0F7FA {
    rectangle "VERBOSE < DEBUG < INFO < WARN < ERROR\n(0)       (1)      (2)     (3)     (4)\n详尽     调试     信息     警告     错误" as levelDesc
}

' ─── Flow Diagram ──────────────────────────────────────────────────

package "日志流程\nLog Flow" as logflow #FFF9C4 {
    usecase "ImeLog.d(tag, msg)\n调用入口" as entry_point
    usecase "ImeLogger\n日志核心" as core
    usecase "CrashInterceptor\n崩溃拦截" as crash
    usecase "LogcatWriter\n控制台输出" as logcat
    usecase "FileLogWriter\n文件输出" as file
    usecase "LogStorage\n文件管理" as storage

    entry_point --> core : "1. 委托"
    core --> crash : "2. 拦截检查"
    core --> logcat : "3. 写入Logcat"
    core --> file : "3. 写入文件"
    file --> storage : "4. 存储管理"
}

' ─── Notes ─────────────────────────────────────────────────────────

note right of ImeLog
    门面模式，全局静态入口。
    所有模块通过 ImeLog 访问日志。
    无需关心底层 Writer 配置。
    
    Facade pattern, global static entry.
    All modules access logging via ImeLog.
    No need to care about Writer configuration.
end note

note left of LogStorage
    文件轮转策略：
    - 单文件最大 2MB
    - 最多保留 5 个文件
    - 自动清理过期日志
    - 崩溃时独立导出
    
    File rotation:
    - Max 2MB per file
    - Max 5 files retained
    - Auto cleanup of old logs
    - Separate dump on crash
end note

note bottom of CrashInterceptor
    维护最近 200 条日志的环形缓冲区。
    当崩溃发生时，将缓冲区内容
    写入独立崩溃日志文件。
    
    Maintains a ring buffer of last 200 entries.
    On crash, dumps buffer to a separate crash log file.
end note

@enduml
