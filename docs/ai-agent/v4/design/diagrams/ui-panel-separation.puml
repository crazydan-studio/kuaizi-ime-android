@startuml ui-panel-separation
!theme plain
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontSize 13
skinparam classFontSize 13

title 筷子输入法 - 三层面板分离\nThree-Layer Panel Separation

' ─── KeyboardPanel Container ───────────────────────────────────────

package "KeyboardPanel\n键盘面板容器" as KPContainer #E3F2FD {

    package "CandidateListPanel\n候选词面板" as CLP #E8F5E9 {
        class CandidateListPanel {
            + candidates: StateFlow<List<Candidate>>
            + onCandidateSelected: (Candidate) -> Unit
            + scrollState: ScrollState
        }
    }

    package "InputListPanel\n输入缓冲面板" as ILP #E8F5E9 {
        class InputListPanel {
            + inputBuffer: StateFlow<String>
            + composingRange: TextRange
            + onBufferClicked: (Int) -> Unit
        }
    }

    package "Toolbar\n工具栏" as TB #E8F5E9 {
        class Toolbar {
            + onAction: (ToolbarAction) -> Unit
            + actions: List<ToolbarAction>
            + isExpanded: StateFlow<Boolean>
        }
    }

    package "GestureInputBox\n手势输入盒" as GIB #FFF3E0 {
        together {
            class KeyGridPanel <<底层 bottom>> #BBDEFB {
                + keyLayout: KeyboardLayout
                + onKeyPress: (KeyAction) -> Unit
                + highlightKey: StateFlow<KeyPos?>
            }
            class GestureFeedbackPanel <<中层 middle>> #C8E6C9 {
                + feedbackLine: StateFlow<GestureLine?>
                + feedbackText: StateFlow<String?>
                + showFeedback: StateFlow<Boolean>
            }
            class GestureInputPanel <<顶层 top>> #FFCCBC {
                + onGesture: (InputGesture) -> Unit
                + gestureDetector: GestureRecognizer
                + isActive: StateFlow<Boolean>
            }
        }
    }
}

' ─── Layer Ordering ────────────────────────────────────────────────

package "层级顺序\nLayer Order (z-index)" as layers #F3E5F5 {
    rectangle "← 顶层 (Top)\nGestureInputPanel\n手势输入面板\n捕获所有触摸事件" as layer3 #FFCCBC
    rectangle "← 中层 (Middle)\nGestureFeedbackPanel\n手势反馈面板\n显示滑行路径和提示" as layer2 #C8E6C9
    rectangle "← 底层 (Bottom)\nKeyGridPanel\n按键网格面板\n显示按键布局" as layer1 #BBDEFB

    layer3 -down-> layer2 : "覆盖\noverlays"
    layer2 -down-> layer1 : "覆盖\noverlays"
}

' ─── Data Flow ─────────────────────────────────────────────────────

package "数据流\nData Flow" as dataflow #E0F7FA {
    usecase "InputGesture\n输入手势" as gesture
    usecase "GestureInputPanel\n手势输入面板" as gip
    usecase "ImeEngine.reduce()\n引擎归约" as reduce
    usecase "StateFlow<ImeState>\n状态流" as stateflow
    usecase "KeyGridPanel\n按键面板" as kgp
    usecase "CandidateListPanel\n候选词面板" as clp_flow

    gesture --> gip : "1. 触摸事件\n向上流动 flows UP"
    gip --> reduce : "2. ImeIntent"
    reduce --> stateflow : "3. 新状态"
    stateflow --> kgp : "4. 更新高亮\n向下流动 flows DOWN"
    stateflow --> clp_flow : "4. 更新候选词\n向下流动 flows DOWN"
}

' ─── Composition ───────────────────────────────────────────────────

KeyboardPanel *-- CandidateListPanel : "包含"
KeyboardPanel *-- InputListPanel : "包含"
KeyboardPanel *-- Toolbar : "包含"
KeyboardPanel *-- KeyGridPanel : "包含"
KeyboardPanel *-- GestureFeedbackPanel : "包含"
KeyboardPanel *-- GestureInputPanel : "包含"

' ─── Layout Hints ──────────────────────────────────────────────────

note right of GIB
    Box 布局层叠关系：
    ┌──────────────────────┐
    │  GestureInputPanel   │ ← 透明, 捕获触摸
    ├──────────────────────┤
    │  GestureFeedbackPanel│ ← 半透明, 显示路径
    ├──────────────────────┤
    │  KeyGridPanel        │ ← 不透明, 按键布局
    └──────────────────────┘
    
    GestureInputPanel 使用 pointerInput
    拦截所有触摸事件，识别手势后
    透传单点击给 KeyGridPanel
end note

@enduml
